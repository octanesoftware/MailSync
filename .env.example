# API Key for authenticating requests
# CHANGE THIS to a strong random string!
API_KEY=your-secure-api-key-here

# Default sync interval in minutes (for syncs without a 'schedule' field)
# Individual syncs can override this with their own cron schedule
# 5 = 5 minutes
# 10 = 10 minutes
# 15 = 15 minutes (default)
# 30 = 30 minutes
SYNC_INTERVAL_MINUTES=15
